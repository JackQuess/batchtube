NODE_ENV=development
PORT=8080
# CORS: frontend origin(s). Production API (api.batchtube.net) must allow https://batchtube.net
ALLOWED_ORIGIN=https://batchtube.net
ALLOWED_ORIGIN_2=https://www.batchtube.net
# Optional: comma-separated list overrides the two above (e.g. CORS_ALLOWED_ORIGINS=https://batchtube.net,https://www.batchtube.net)
# CORS_ALLOWED_ORIGINS=
# Local Postgres
# Prisma requires the scheme to be exactly "postgresql://" (not "postgres://"). No spaces or line breaks in the URL.
# If your password contains @ # ? / etc., URL-encode them (e.g. @ → %40).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/batchtube?schema=public
# For migrate deploy use direct connection (avoids "prepared statement already exists" with pooler)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/batchtube?schema=public
# Railway + Supabase (recommended: transaction pooler, not db.<ref>.supabase.co:5432)
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres (for migrations only)

# Redis (required for queues, rate limit, idempotency).
# Local: use redis://localhost:6379 (must have Redis running locally).
# Railway: use the Redis URL from your Redis service. Inside Railway, REDIS_PRIVATE_URL uses
#   host redis.railway.internal (only resolves inside Railway). Do NOT use redis.railway.internal
#   when running the app locally or outside Railway — it will fail with EAI_AGAIN / ETIMEDOUT.
REDIS_URL=redis://localhost:6379

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Optional: comma-separated user UUIDs that bypass plan restrictions for API keys (create/use keys on any plan). Set to your Supabase user id(s) with app_metadata.role=admin.
# ADMIN_USER_IDS=

PADDLE_API_BASE=https://api.paddle.com
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_PRO=
PADDLE_PRICE_ID_ARCHIVIST=
PADDLE_PRICE_ID_ENTERPRISE=
PADDLE_SUCCESS_URL=
PADDLE_CANCEL_URL=

# Lemon Squeezy (optional – use instead of Paddle)
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_VARIANT_PRO=
# LEMONSQUEEZY_VARIANT_ULTRA=

# R2 / S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
# Optional AWS aliases (used if S3_ACCESS_KEY/S3_SECRET_KEY are not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
S3_BUCKET=batchtube
S3_FORCE_PATH_STYLE=true
# Set true for providers where bucket create/check should be skipped (e.g. Cloudflare R2)
S3_SKIP_BUCKET_ENSURE=false

# Railway runtime (set per service in Railway Variables)
# API service: SERVICE_ENTRY=server
# Download worker service: SERVICE_ENTRY=download-worker
# Processing worker service: SERVICE_ENTRY=processing-worker

# Worker concurrency:
# - WORKER_CONCURRENCY: legacy global default (also used for provider caps)
# - WORKER_CONCURRENCY_DOWNLOAD: download-worker concurrency (defaults to WORKER_CONCURRENCY)
# - WORKER_CONCURRENCY_PROCESSING: processing-worker concurrency (defaults to WORKER_CONCURRENCY, typically lower)
# Higher values increase throughput but may hit provider rate limits or memory.
# Optional per-provider caps for download-worker (effective cap = min(global, provider)):
#   e.g. WORKER_CONCURRENCY_YOUTUBE=5, WORKER_CONCURRENCY_VIMEO=15
# WORKER_CONCURRENCY=20
# WORKER_CONCURRENCY_DOWNLOAD=20
# WORKER_CONCURRENCY_PROCESSING=10

# Optional: only for age-restricted / login-required content (e.g. some YouTube). Not required for normal downloads.
# Worker auto-refreshes when cookies are stale (by real expiry or within 2 days). Runs on startup and every 12h.
# On Railway/Docker use a path inside the container (e.g. /app/cookies/cookies.txt), not your local machine path.
# YT_DLP_COOKIES_FILE=/path/to/cookies.txt
# Optional: import cookies from a browser profile on the worker host.
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_COOKIES_FROM_BROWSER_PROFILE=Default

# yt-dlp reliability tuning (optional). Defaults are optimized for fast first attempt and safer fallback retries.
# YT_DLP_TIMEOUT_MS=300000
# YT_DLP_SOCKET_TIMEOUT_SEC=20
# YT_DLP_RETRIES_FAST=1
# YT_DLP_RETRIES_SAFE=3
# YT_DLP_FRAGMENT_RETRIES_FAST=1
# YT_DLP_FRAGMENT_RETRIES_SAFE=3
# YT_DLP_EXTRACTOR_RETRIES_FAST=1
# YT_DLP_EXTRACTOR_RETRIES_SAFE=3
# YT_DLP_YOUTUBE_MAX_ATTEMPTS=10
# YT_DLP_YOUTUBE_BACKOFF_BASE_MS=1000
# YT_DLP_MIN_VERSION_DATE=2025.01.01

# Provider smoke checks (optional but strongly recommended in production).
# JSON map: provider -> representative public URL.
# Include all providers from Supports Sites for real coverage.
# PROVIDER_SMOKE_URLS_JSON={"youtube":"https://www.youtube.com/watch?v=dQw4w9WgXcQ","vimeo":"https://vimeo.com/76979871"}
# Smoke run timeout per provider probe.
# PROVIDER_SMOKE_TIMEOUT_MS=25000
# Minimum time between auto-cached smoke runs.
# PROVIDER_SMOKE_MIN_INTERVAL_MS=600000
# CI/cron required success ratio for runnable providers (ok/(ok+failed)).
# PROVIDER_SMOKE_REQUIRED_SUCCESS_RATE=0.85

# Optional: URL to fetch fresh cookies when stale (default: yt-dlp template). Set to your own endpoint if you serve cookies.
# COOKIE_REFRESH_URL=
# Optional: On first deploy / when cookie file is missing, worker downloads from this URL and writes to YT_DLP_COOKIES_FILE. Use a private raw URL (e.g. GitHub secret Gist raw link). See api/RAILWAY_COOKIES.md.
# COOKIES_INIT_URL=
